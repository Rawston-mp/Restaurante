# Banco de dados SQLite
# Para produção, pode ser alterado para um banco remoto (ex: Turso/LibSQL)
DATABASE_URL="file:./dev.db"

# Segredo da sessão — mude para uma string aleatória de 32+ caracteres em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-por-uma-string-aleatoria-de-32-caracteres-minimo"

# Nome público do restaurante (opcional)
NEXT_PUBLIC_RESTAURANT_NAME="Meu Restaurante"
